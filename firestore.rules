rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: groups
    // Fields:
    //   - name: string (required)
    //   - createdAt: number (required)
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - groupId: string (required)
    //   - groupName: string (required)
    //   - purchaseRate: number (required)
    //   - mrp: number (required)
    //   - stock: number (required)
    //   - unit: string (required)
    //   - updatedAt: number (required)
    //
    // Collection: bills
    // Fields:
    //   - billNo: string (required)
    //   - customerName: string (required)
    //   - customerPhone: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - paidAmount: number (required)
    //   - dueAmount: number (required)
    //   - date: number (required)
    //
    // Collection: dues
    // Fields:
    //   - customerPhone: string (required)
    //   - customerName: string (required)
    //   - totalDue: number (required)
    //   - lastBillDate: number (required)
    //   - lastUpdated: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "subhadipmondal0101@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is number;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'groupId', 'groupName', 'purchaseRate', 'wholesaleRate', 'mrp', 'stock', 'unit', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.groupId is string &&
             data.groupName is string &&
             data.purchaseRate is number && data.purchaseRate >= 0 &&
             data.wholesaleRate is number && data.wholesaleRate >= 0 &&
             data.mrp is number && data.mrp >= 0 &&
             data.stock is number &&
             data.unit is string &&
             data.updatedAt is number;
    }

    function isValidBill(data) {
      return data.keys().hasAll(['billNo', 'customerName', 'customerPhone', 'items', 'subtotal', 'grandTotal', 'paidAmount', 'dueAmount', 'date']) &&
             data.billNo is string &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerPhone is string &&
             data.items is list &&
             data.subtotal is number &&
             data.grandTotal is number &&
             data.paidAmount is number &&
             data.dueAmount is number &&
             data.date is number;
    }

    function isValidDue(data) {
      return data.keys().hasAll(['customerPhone', 'customerName', 'amount', 'lastBillDate']) &&
             data.customerPhone is string &&
             data.customerName is string &&
             data.amount is number &&
             data.lastBillDate is number;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['fullName', 'lastAccess']) &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.lastAccess is number;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['password']) &&
             data.password is string && data.password.size() > 0;
    }

    // Rules
    match /profiles/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == uid && isValidProfile(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /groups/{groupId} {
      allow read, write: if isAuthenticated();
    }
    
    match /subgroups/{subgroupId} {
      allow read, write: if isAuthenticated();
    }

    match /products/{productId} {
      allow read, write: if isAuthenticated();
    }

    match /bills/{billId} {
      allow read, write: if isAuthenticated();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
    }

    match /dues/{dueId} {
      allow read, write: if isAuthenticated();
    }
  }
}
