{
  "entities": {
    "Group": {
      "title": "Product Group",
      "description": "A category for products (e.g., Company Name)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the group" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["name", "createdAt"]
    },
    "Subgroup": {
      "title": "Product Subgroup",
      "description": "A sub-category for products (e.g., Liquid, Soap)",
      "type": "object",
      "properties": {
        "groupId": { "type": "string", "description": "ID of the parent group" },
        "name": { "type": "string", "description": "Name of the subgroup" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["groupId", "name", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in stock",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "groupId": { "type": "string", "description": "ID of the group it belongs to" },
        "groupName": { "type": "string", "description": "Name of the group it belongs to" },
        "subgroupId": { "type": "string", "description": "ID of the subgroup it belongs to" },
        "subgroupName": { "type": "string", "description": "Name of the subgroup it belongs to" },
        "purchaseRate": { "type": "number", "description": "Cost price" },
        "wholesaleRate": { "type": "number", "description": "Wholesale price" },
        "mrp": { "type": "number", "description": "Selling price" },
        "stock": { "type": "number", "description": "Current stock quantity" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g., Pcs, Kg)" },
        "updatedAt": { "type": "number", "description": "Timestamp of last update" }
      },
      "required": ["name", "groupId", "subgroupId", "purchaseRate", "wholesaleRate", "mrp", "stock", "unit", "updatedAt"]
    },
    "Bill": {
      "title": "Bill",
      "description": "A sales transaction",
      "type": "object",
      "properties": {
        "billNo": { "type": "string", "description": "Unique bill number" },
        "customerName": { "type": "string", "description": "Name of the customer" },
        "customerPhone": { "type": "string", "description": "Phone number of the customer" },
        "additionalPhones": { "type": "array", "items": { "type": "string" }, "description": "Additional phone numbers" },
        "customerAddress": { "type": "string", "description": "Address of the customer" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "qty": { "type": "number" },
              "rate": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "dueAmount": { "type": "number" },
        "date": { "type": "number" }
      },
      "required": ["billNo", "customerName", "customerPhone", "totalAmount", "paidAmount", "dueAmount", "date"]
    },
    "CustomerDue": {
      "title": "Customer Due",
      "description": "Outstanding balance for a customer",
      "type": "object",
      "properties": {
        "customerPhone": { "type": "string" },
        "additionalPhones": { "type": "array", "items": { "type": "string" }, "description": "Additional phone numbers" },
        "customerName": { "type": "string" },
        "customerAddress": { "type": "string" },
        "totalDue": { "type": "number" },
        "lastBillDate": { "type": "number" },
        "lastUpdated": { "type": "number" }
      },
      "required": ["customerPhone", "customerName", "totalDue", "lastBillDate", "lastUpdated"]
    },
    "Profile": {
      "title": "User Profile",
      "description": "User profile with full name",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "lastAccess": { "type": "number" }
      },
      "required": ["fullName", "lastAccess"]
    },
    "Settings": {
      "title": "App Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "password": { "type": "string" }
      },
      "required": ["password"]
    }
  },
  "firestore": {
    "/groups": { "schema": "Group", "description": "Collection of product groups" },
    "/subgroups": { "schema": "Subgroup", "description": "Collection of product subgroups" },
    "/products": { "schema": "Product", "description": "Collection of products" },
    "/bills": { "schema": "Bill", "description": "Collection of sales bills" },
    "/dues": { "schema": "CustomerDue", "description": "Collection of customer dues" },
    "/profiles": { "schema": "Profile", "description": "Collection of user profiles" },
    "/settings": { "schema": "Settings", "description": "Collection of app settings" }
  }
}
